# ============================================================
# CPT — Environment Variables Template
# Copy this file to .env and fill in your real values.
# .env is gitignored — never commit it.
# ============================================================

# ------------------------------------------------------------
# Database
# Default: SQLite (no setup needed, good for local development)
# Production: switch to PostgreSQL by changing this URL
# ------------------------------------------------------------
DATABASE_URL=sqlite:///data/cpt.db
# DATABASE_URL=postgresql://user:password@localhost:5432/cpt

# ------------------------------------------------------------
# Redis (for caching and alert deduplication)
# Default: local Redis on standard port
# ------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# ------------------------------------------------------------
# Model Weights Directory
# ------------------------------------------------------------
MODEL_DIR=models

# ------------------------------------------------------------
# ENGINE 1 — Macroeconomic
# ------------------------------------------------------------

# FRED API (free at https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=your_fred_api_key_here

# ------------------------------------------------------------
# ENGINE 2 — On-Chain Analytics
# ------------------------------------------------------------

# DeFiLlama API (free, no API key required)
# Endpoint: https://api.llama.fi -- SOL TVL, DeFi protocol metrics
# No registration needed.
DEFILLAMA_BASE_URL=https://api.llama.fi

# Blockchair API (free tier, no API key required for basic use)
# Endpoint: https://api.blockchair.com -- DOGE active addresses, tx volume
# Free limit: 1000 req/day, 30 req/min.
BLOCKCHAIR_BASE_URL=https://api.blockchair.com

# Solana RPC Endpoint
# Recommended: Alchemy (https://www.alchemy.com) or Helius (https://helius.dev)
# Public endpoints are unreliable for production use.
SOL_RPC_URL=https://api.mainnet-beta.solana.com

# Dogecoin Core JSON-RPC (requires running a local dogecoin-core node, ~60 GB)
# See: https://dogecoin.com/dogepedia/how-tos/operating-a-node/
DOGE_RPC_URL=http://localhost:22555
DOGE_RPC_USER=your_dogecoin_rpc_username
DOGE_RPC_PASS=your_dogecoin_rpc_password

# ------------------------------------------------------------
# ENGINE 3 — Social Sentiment
# ------------------------------------------------------------

# Twitter/X API v2 (Basic tier at https://developer.twitter.com)
# Basic tier: 500k tweet reads/month. Academic tier needed for 90+ day backfill.
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here

# Reddit API (free at https://www.reddit.com/prefs/apps)
# Create a "script" app type. Rate limit: 60 req/min.
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
REDDIT_USER_AGENT=CPT/1.0 by your_reddit_username

# Telegram API (register at https://my.telegram.org/auth)
# Required for Telethon to access public channel messages.
TELEGRAM_API_ID=your_telegram_api_id_here
TELEGRAM_API_HASH=your_telegram_api_hash_here

# ------------------------------------------------------------
# NOTIFICATIONS — Discord
# ------------------------------------------------------------

# Discord Webhook URL (create in Server Settings → Integrations → Webhooks)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_id/your_webhook_token

# Optional: Discord Bot Token (only needed for advanced bot features)
# DISCORD_BOT_TOKEN=your_discord_bot_token_here

# ------------------------------------------------------------
# NOTIFICATIONS — WhatsApp (via Twilio)
# ------------------------------------------------------------

# Twilio credentials (https://console.twilio.com)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here

# Sender number:
# Development: use Twilio sandbox number +14155238886
# Production: use your approved Twilio WhatsApp sender number
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Your WhatsApp number to receive messages (include country code)
TWILIO_WHATSAPP_TO=whatsapp:+84xxxxxxxxx

# ------------------------------------------------------------
# NOTIFICATIONS — Zalo (Official Account API v2)
# ------------------------------------------------------------

# Register a Zalo Official Account at https://oa.zalo.me
# Then create an app at https://developers.zalo.me
ZALO_APP_ID=your_zalo_app_id_here
ZALO_APP_SECRET=your_zalo_app_secret_here

# Access token expires every 1 hour — zalo_notifier.py refreshes it automatically
ZALO_OA_ACCESS_TOKEN=your_zalo_oa_access_token_here
ZALO_REFRESH_TOKEN=your_zalo_refresh_token_here

# ------------------------------------------------------------
# Prediction Alert Thresholds (optional overrides)
# Defaults are set in config/constants.py
# Uncomment to override without changing code.
# ------------------------------------------------------------
# ALERT_CONFIDENCE_THRESHOLD=0.70
# ALERT_MIN_MOVE_PCT=3.0
# WHALE_THRESHOLD_USD=500000
# ELON_DOGE_MULTIPLIER=3.0

# ------------------------------------------------------------
# Scheduler Intervals (optional overrides, values in minutes)
# ------------------------------------------------------------
# DATA_FETCH_INTERVAL_MIN=15
# PREDICTION_INTERVAL_MIN=60

# ------------------------------------------------------------
# Live Server
# ------------------------------------------------------------
# SERVER_HOST=0.0.0.0
# SERVER_PORT=8000
# SERVER_RELOAD=False   # Set to True only in development
